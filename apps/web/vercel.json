{
  "buildCommand": "cd ../.. && if [ \"$VERCEL_ENV\" = preview ] && [ \"$IS_OAUTH_PROXY_SERVER\" != true ]; then NEXT_PUBLIC_BASE_URL=https://$VERCEL_URL turbo run build --force --filter={apps/web}...; else turbo run build --filter={apps/web}...; fi",
  "installCommand": "cd ../.. && corepack enable && bash clone-marketing.sh && pnpm install --no-frozen-lockfile",
  "ignoreCommand": "bash scripts/vercel-ignore-build.sh",
  "rewrites": [
    {
      "source": "/tools",
      "destination": "https://mini-apps-cyan.vercel.app/tools"
    },
    {
      "source": "/tools/:path+",
      "destination": "https://mini-apps-cyan.vercel.app/tools/:path+"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/scheduled-actions",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/watch/all",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/resend/digest/all",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/reasoning-retention",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/draft-cleanup",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/follow-up-reminders",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/automation-jobs",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/meeting-briefs",
      "schedule": "0 7 * * *"
    }
  ]
}
